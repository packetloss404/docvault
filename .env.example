# ==========================================================================
# DocVault Environment Configuration
# Copy to docvault/.env and adjust values for your environment.
# Required vars are uncommented. Optional vars are commented with #.
# ==========================================================================

# === Core ===
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=docvault.settings.development
DJANGO_LOG_LEVEL=DEBUG

# === Database ===
DATABASE_URL=postgresql://docvault:docvault@localhost:5432/docvault

# === Redis ===
REDIS_URL=redis://localhost:6379

# === File Storage ===
MEDIA_ROOT=./media
STATIC_ROOT=./staticfiles
# STORAGE_BACKEND=local
# S3_ENDPOINT_URL=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET_NAME=docvault
# S3_REGION=us-east-1

# === CORS ===
# CORS_ALLOWED_ORIGINS=http://localhost:4200

# === OIDC / SSO (optional) ===
# OIDC_SERVER_URL=
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=

# === LDAP (optional) ===
# LDAP_ENABLED=false

# === Elasticsearch (optional) ===
# ELASTICSEARCH_ENABLED=false
# ELASTICSEARCH_URL=http://localhost:9200

# === OCR ===
# OCR_LANGUAGE=eng
# OCR_MODE=skip
# OCR_IMAGE_DPI=300
# OCR_DESKEW=true
# OCR_ROTATE=true

# === LLM / AI (optional) ===
# LLM_ENABLED=false
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4
# LLM_API_KEY=
# EMBEDDING_MODEL=text-embedding-3-small
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_DEPLOYMENT=

# === Storage Encryption (optional) ===
# STORAGE_ENCRYPTION_ENABLED=false

# === Sentry (optional) ===
# SENTRY_DSN=
